# Backend
PORT=3001
ENFORCE_RBAC=true
WEBHOOK_SECRET=change_this_secret

# OpenTelemetry (optional)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=siag-backend
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Frontend / NextAuth
NEXTAUTH_SECRET=change_this_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_USER_EMAIL=

# Shared DB for local dev (SQLite)
DATABASE_URL=file:./apps/backend/prisma/dev.db
